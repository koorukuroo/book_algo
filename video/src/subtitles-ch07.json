    {
      "text": "같은 원리가 일상에도 작동합니다.",
      "fromFrame": 2053,
      "toFrame": 2150,
      "scene": "regularize"
    },
    {
      "text": "늦지 않게 결정하라, 너무 많이 고민하지",
      "fromFrame": 2151,
      "toFrame": 2257,
      "scene": "regularize"
