      "fromFrame": 273,
      "toFrame": 354,
      "scene": "hook"
    },
    {
      "text": "룸메이트는 빨래 통에서 양말 두 개를",
      "fromFrame": 354,
      "toFrame": 440,
      "scene": "hook"
